# VERCEL - Environment Variables
# Copie essas variáveis no painel do Vercel (Settings > Environment Variables)

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_super_secreto
API_KEY=sua_chave_api_meudanfe

# Como preencher:
# 1. SUPABASE_URL: Copie em Supabase > Project Settings > API > URL
# 2. SUPABASE_SERVICE_ROLE_KEY: Copie em Supabase > Project Settings > API > Service Role secret
# 3. API_KEY: Sua chave de API do meudanfe.com.br

# ⚠️ NUNCA compartilhe essas credenciais
# ⚠️ Use sempre a SERVICE_ROLE_KEY (não a anon key) no backend
